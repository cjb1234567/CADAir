# 百度翻译API配置
# 从 https://fanyi-api.baidu.com/ 获取
APP_ID=your_app_id_here
SEC_KEY=your_secret_key_here

# ODA File Converter 路径 (用于读写DWG文件)
# Windows 示例:
ODA_PATH=C:\Program Files\ODA\ODAFileConverter 27.1.0\ODAFileConverter.exe
# Linux/WSL 示例:
# ODA_PATH=/mnt/c/Program Files/ODA/ODAFileConverter 27.1.0/ODAFileConverter.exe
# Mac 示例:
# ODA_PATH=/Applications/ODAFileConverter.app/Contents/MacOS/ODAFileConverter
