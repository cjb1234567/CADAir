# 百度翻译API配置
# 从 https://fanyi-api.baidu.com/ 获取
APP_ID=your_app_id_here
SEC_KEY=your_secret_key_here

# ODA File Converter 路径 (用于读写DWG文件)
# Windows 示例:
# ODA_PATH=C:\Program Files\ODA\ODAFileConverter 27.1.0\ODAFileConverter.exe
# Linux/WSL 示例:
# ODA_PATH=/mnt/c/Program Files/ODA/ODAFileConverter 27.1.0/ODAFileConverter.exe
# Linux AppImage 示例:
# ODA_PATH=/path/to/ODAFileConverter.AppImage
# Mac 示例:
# ODA_PATH=/Applications/ODAFileConverter.app/Contents/MacOS/ODAFileConverter

# ─────────────────────────────────────────────
# 可选配置项 (Optional)
# ─────────────────────────────────────────────

# 翻译目标语言
# 常用值: en(英语), zh(中文), jp(日语), kor(韩语), fra(法语), spa(西班牙语)
# 默认值: en
# TRANSLATE_TARGET=zh

# 翻译源语言
# 默认值: auto (自动检测)
# TRANSLATE_SOURCE=en

# 翻译领域 (仅适用于百度领域翻译API)
# 常用值: machinery(机械), electricity(电力), electronics(电子), finance(金融)
# 默认值: machinery
# TRANSLATE_DOMAIN=machinery

# QPS限制 (每秒请求数)，根据百度API配额调整
# 默认值: 5
# TRANSLATE_QPS=10

# 使用通用翻译API (y=通用, n=领域)
# 默认值: y
# TRANSLATE_USE_GENERAL=y
