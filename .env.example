# 百度翻译API配置
# 从 https://fanyi-api.baidu.com/ 获取
APP_ID=your_app_id_here
SEC_KEY=your_secret_key_here

# ODA File Converter 路径 (用于读写DWG文件)
# Windows 示例:
# ODA_PATH=C:\Program Files\ODA\ODAFileConverter 27.1.0\ODAFileConverter.exe
# Linux/WSL 示例:
# ODA_PATH=/mnt/c/Program Files/ODA/ODAFileConverter 27.1.0/ODAFileConverter.exe
# Linux AppImage 示例:
# ODA_PATH=/path/to/ODAFileConverter.AppImage
# Mac 示例:
# ODA_PATH=/Applications/ODAFileConverter.app/Contents/MacOS/ODAFileConverter

# ─────────────────────────────────────────────
# 可选配置项 (Optional)
# ─────────────────────────────────────────────

# 翻译目标语言
# 常用值: en(英语), zh(中文), jp(日语), kor(韩语), fra(法语), spa(西班牙语)
# 默认值: en
# TRANSLATE_TARGET=zh

# 翻译源语言
# 默认值: auto (自动检测)
# TRANSLATE_SOURCE=en

# 翻译领域 (仅适用于百度领域翻译API)
# 常用值: machinery(机械), electricity(电力), electronics(电子), finance(金融)
# 默认值: machinery
# TRANSLATE_DOMAIN=machinery

# QPS限制 (每秒请求数)，根据百度API配额调整
# 默认值: 1.0 for CLI/service defaults
# TRANSLATE_QPS=1.0

# 使用通用翻译API (y=通用, n=领域)
# 默认值: y
# TRANSLATE_USE_GENERAL=y

# CAD/电气柜术语配置。terms 会跳过翻译；translations 会精确命中固定译文。
# 支持 JSON 数组、{"terms": [...], "translations": {...}} 对象，或逗号分隔的命令行简写。
# FastAPI service mode can also receive request-level input.params.glossary_json.
# GLOSSARY_JSON=["ODF","PDU","CCU","ETH","RUN","ALM","PWR"]
# GLOSSARY_FILE=config/cad_glossary_zh-en.json

# 微服务/容器部署路径配置
# 上传文件由 Gateway/平台写入 CADAIR_UPLOAD_ROOT；CADAir 只读取平台白名单路径。
# 交付文件写入 CADAIR_OUTPUT_ROOT/apps-style 目录，OneDrive 分发由 Gateway 负责。
# CADAIR_OUTPUT_ROOT=/data/deliveries/apps
# CADAIR_UPLOAD_ROOT=/data/uploads
# CADAIR_ALLOWED_INPUT_ROOTS=/data/uploads,/data/document-intelligence,/data/deliveries
# 设置后，CLI 和后续服务模式的中间文件不会写入输入文件目录，适合只读 /data/uploads。
# CADAIR_WORK_ROOT=/data/deliveries/apps/cadair_translate/_work
# 设置后才写 translation.log；不设置时只写进程日志流。
# CADAIR_LOG_DIR=/data/deliveries/apps/cadair_translate/_logs

# ODA 运行时配置
# CADAIR_ODA_RUNTIME_DIR=/tmp/runtime-cadair
# CADAIR_ODA_TIMEOUT_SECONDS=120
